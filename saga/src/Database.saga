module SeshImporter.Database

import Std.DateTime (Date)
import Std.Dynamic (decode_element, int)
import SagaPgo (
  Config,
  Postgres,
  Connection,
  QueryError,
  Returned,
  connect,
  default_config,
  execute,
  pg,
  pg_transaction,
  push,
  push_values,
  sql,
  transaction
)
import SagaPgo.Types (pg_int, pg_text, pg_date, maybe_null)
import SeshImporter.Gear
import SeshImporter.Parsers (Normalized, Sport, SeshType)

effect DbCtx {
  fun conn : Unit -> Connection
}

fun stringify_sport : Sport -> String
stringify_sport sport = case sport {
  Kiteboarding -> "kiteboarding"
  Sup -> "sup"
  Skiing -> "skiing"
  Snowboarding -> "snowboarding"
  MountainBiking -> "mountain biking"
  Hiking -> "hiking"
  Running -> "running"
  Paragliding -> "paragliding"
  Surfing -> "surfing"
  WingFoiling -> "wing foiling"
  Parawinging -> "parawinging"
}

fun stringify_sesh_type : SeshType -> String
stringify_sesh_type st = case st {
  Spot -> "spot"
  Downwinder -> "downwinder"
  Roundwinder -> "roundwinder"
}

fun hours_to_seconds : Float -> Int
hours_to_seconds hours = Float.ceil (hours * 60.0 * 60.0)

fun is_wind_sport : Sport -> Bool
is_wind_sport sport = case sport {
  Kiteboarding -> True
  WingFoiling -> True
  Parawinging -> True
  _ -> False
}

pub record WindDetails {
  wind_avg: Int,
  wind_gust: Int,
  sesh_type: String,
} deriving (Debug)

# Validates wind sports have required wind details.
# Non-wind sports always have no wind details.
fun wind_details_from : Normalized -> Maybe WindDetails
wind_details_from n = case (
  is_wind_sport n.sport,
  n.wind_avg,
  n.wind_gust,
  n.sesh_type,
) {
  (True, Just avg, Just gust, Just st) ->
    Just (WindDetails {
      wind_avg: avg,
      wind_gust: gust,
      sesh_type: stringify_sesh_type st,
    })
  (True, _, _, _) -> panic $"Wind sport missing wind data: {debug n}"
  (False, _, _, _) -> Nothing
}

record MappedSesh {
  user_id: Int,
  date: Date,
  sport: String,
  duration_seconds: Int,
  location: Maybe String,
  comments: Maybe String,
  wind_details: Maybe WindDetails,
  gear_ids: List Int,
} deriving (Debug)

fun from_normalized : Normalized -> MappedSesh
from_normalized n = MappedSesh {
  user_id: 1,
  date: n.date,
  sport: stringify_sport n.sport,
  duration_seconds: hours_to_seconds n.hours,
  location: n.location,
  comments: n.comments,
  wind_details: wind_details_from n,
  gear_ids: Gear.gear_ids n,
}

fun decode_id : (row: Std.Dynamic.Dynamic) -> Int
decode_id row = case decode_element 0 int row {
  Ok n -> n
  Err e -> panic $"Failed to decode id from RETURNING row: {debug e}"
}

#@ Inserts all base seshes and zips into a tuple paired with its inserted id
fun insert_seshes : List MappedSesh
  -> Result (List (Int, MappedSesh)) QueryError
  needs {Postgres, DbCtx}
insert_seshes mapped = {
  sql "INSERT INTO seshes (user_id, date, sport, duration_seconds, location_name, comments)"
  |> push_values mapped (fun m -> [
    pg_int m.user_id,
    pg_date m.date,
    pg_text m.sport,
    pg_int m.duration_seconds,
    maybe_null pg_text m.location,
    maybe_null pg_text m.comments,
  ])
  |> push "RETURNING id"
  |> execute (conn! ())
  |> Result.map (fun returned -> {
    let ids = List.map decode_id returned.rows
    List.zip ids mapped
  })
}

# Pair each (sesh_id, MappedSesh) with its WindDetails when present
fun wind_rows : (with_ids: List (Int, MappedSesh)) -> List (Int, WindDetails)
wind_rows = List.filter_map (fun pair -> case pair {
  (sesh_id, m) -> case m.wind_details {
    Just wd -> Just (sesh_id, wd)
    Nothing -> Nothing
  }
})

fun insert_wind_details : (with_ids: List (Int, MappedSesh))
  -> Result Int QueryError
  needs {Postgres, DbCtx}
insert_wind_details with_ids = {
  let rows = wind_rows with_ids
  case rows {
    [] -> Ok 0
    _ -> {
      sql "INSERT INTO wind_sesh_details (sesh_id, wind_avg, wind_gust, sesh_type)"
      |> push_values rows (fun (sesh_id, wd) -> [
        pg_int sesh_id,
        pg_int wd.wind_avg,
        pg_int wd.wind_gust,
        pg_text wd.sesh_type,
      ])
      |> execute (conn! ())
      |> Result.map (fun returned -> returned.count)
    }
  }
}

# Flattens each sesh's gear_ids into (sesh_id, gear_id) pairs
fun gear_rows : (with_ids: List (Int, MappedSesh)) -> List (Int, Int)
gear_rows =
  List.flat_map (fun (sesh_id, m) ->
    List.map (fun gid -> (sesh_id, gid)) m.gear_ids)

fun bind_gear_row : (Int, Int) -> List Types.Value
bind_gear_row (sesh_id, gear_id) = [pg_int sesh_id, pg_int gear_id]

fun insert_gear : (with_ids: List (Int, MappedSesh)) -> Result Int QueryError
  needs {Postgres, DbCtx}
insert_gear with_ids = {
  case gear_rows with_ids {
    [] -> Ok 0
    rows -> {
      sql "INSERT INTO sesh_gear (sesh_id, gear_id)"
      |> push_values rows bind_gear_row
      |> execute (conn! ())
      |> Result.map (fun returned -> returned.count)
    }
  }
}

db_config =
  { default_config "seshtracker_dev" | user: "dylan", password: "dylan" }

pub fun insert_records : (normalized: List Normalized) -> Unit
insert_records normalized = {
  let db_conn = connect db_config
  let mapped = List.map from_normalized normalized

  let result = transaction db_conn (fun () -> {
    do {
      Ok with_ids <- insert_seshes mapped
      Ok wind_count <- insert_wind_details with_ids
      Ok gear_count <- insert_gear with_ids
      Ok (List.length with_ids, wind_count, gear_count)
    } else {
      Err e -> Err e
    }
  } with {
    conn () = resume db_conn
  })

  case result {
    Ok (sesh_count, wind_count, gear_count) -> {
      println $"Inserted {sesh_count} seshes"
      println $"Inserted {wind_count} wind details"
      println $"Inserted {gear_count} gear records"
    }
    Err e -> panic $"insert_records failed: {debug e}"
  }
} with {pg_transaction, pg, console}
