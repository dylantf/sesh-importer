  location: row |> get_field "Location" |> maybe_string,
  comments: row |> get_field "Comments" |> maybe_string,
}

pub fun parse_file : (year: Int) -> (path: String) -> List Normalized
  needs {File}
parse_file year path = {
  let contents = case File.read! path {
    Ok content -> content
    Err _ -> panic $"Failed to read {path}"
  }
  let rows = reader () |> parse_keyed contents
  case year {
    2012 -> List.map from_2012 rows
    2013 -> List.map from_2013 rows
    2014 -> List.map from_2014 rows
    2015 -> List.map from_2015 rows
    2016 | 2017 | 2018 | 2019 | 2020 | 2021 -> List.map from_2016 rows
    2022 | 2023 | 2024 -> List.map from_2022 rows
    2025 | 2026 -> List.map from_2025 rows
    _ -> panic $"No parser for year {show year}"
  }
}
