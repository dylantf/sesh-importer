  sport: row |> get_field "Sport" |> parse_sport,
  hours: row |> get_field "Hours" |> parse_hours,
  wind_avg: row |> get_field "Avg (kts)" |> parse_optional_int,
  wind_gust: row |> get_field "Gust (kts)" |> parse_optional_int,
  kite_size: row |> get_field "Kite" |> parse_many |> normalize_kite_sizes,
  wing_size: row |> get_field "Wing" |> parse_many,
  sesh_type: row |> get_field "Type" |> parse_sesh_type,
  board_type: row |> get_field "Board Type" |> parse_board_types,
  foil: row |> get_field "Foil" |> parse_many,
