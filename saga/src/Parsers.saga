from_2016 row = Normalized {
  date: row |> get_field "Date" |> parse_date,
  sport: row |> get_field "Sport" |> parse_sport,
  hours: row |> get_field "Hours" |> parse_hours,
  wind_avg: row |> get_field "Lull (kts)" |> parse_optional_int,
  wind_gust: row |> get_field "Gust (kts)" |> parse_optional_int,
  kite_size: row |> get_field "Kite" |> parse_many |> normalize_kite_sizes,
  wing_size: Nothing,
  sesh_type: row |> get_field "Type" |> parse_sesh_type,
  board_type: row |> get_field "Board" |> parse_board_types,
  foil: Nothing,
  foil_board: Nothing,
  location: row |> get_field "Location" |> maybe_string,
  comments: row |> get_field "Comments" |> maybe_string,
}

fun from_2022 : (row: Dict String String) -> Normalized
from_2022 row = Normalized {
  date: row |> get_field "Date" |> parse_date,
  sport: row |> get_field "Sport" |> parse_sport,
  hours: row |> get_field "Hours" |> parse_hours,
  wind_avg: row |> get_field "Avg (kts)" |> parse_optional_int,
  wind_gust: row |> get_field "Gust (kts)" |> parse_optional_int,
  kite_size: row |> get_field "Kite" |> parse_many |> normalize_kite_sizes,
  wing_size: row |> get_field "Wing" |> parse_many,
  sesh_type: row |> get_field "Type" |> parse_sesh_type,
  board_type: row |> get_field "Board Type" |> parse_board_types,
  foil: row |> get_field "Foil" |> parse_many,
  foil_board: row |> get_field "Foil Board" |> maybe_string,
  location: row |> get_field "Location" |> maybe_string,
  comments: row |> get_field "Comments" |> maybe_string,
}

