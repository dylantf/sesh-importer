module SeshImporter

import Std.Env (Env, system_env)
import Std.File (File, fs)
import SeshImporter.Database
import SeshImporter.Gear
import SeshImporter.Parsers (parse_file)

import_path year = {
  let home =
    Env.get! "HOME"
    |> Maybe.unwrap_or "/home/dylan"

  $"{home}/Desktop/Sesh Import/{year}.csv"
} with system_env

main () = {
  let normalized =
    List.range 2012 2026
    |> List.flat_map (fun year -> parse_file year (import_path year))

  Database.insert_records normalized
}
